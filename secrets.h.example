#pragma once

// Copy this file to secrets.h and fill in your TTN device credentials.
// All three values are MSB first, exactly as shown in the TTN console.

// Device EUI (8 bytes, MSB first)
uint8_t DevEUI[8]  = { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 };

// Join EUI / App EUI (8 bytes, MSB first)
uint8_t JoinEUI[8] = { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 };

// App Key (16 bytes, MSB first)
uint8_t AppKey[16] = { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
                       0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 };
