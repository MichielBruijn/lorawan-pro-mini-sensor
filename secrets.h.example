// LoRaWAN credentials — copy this file to secrets.h and fill in your values.
// Register your device at https://www.thethingsnetwork.org/ to obtain these keys.
//
// APPEUI & DEVEUI: LSB first (reverse byte order from TTN)
// APPKEY: MSB first (as shown in TTN)

static const u1_t PROGMEM APPEUI[8] = {
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
};

static const u1_t PROGMEM DEVEUI[8] = {
  0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF, 0x00, 0x11
};

static const u1_t PROGMEM APPKEY[16] = {
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
};
